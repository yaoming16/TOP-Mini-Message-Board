<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+Mono:wght@100..900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />
    <title>Mini Message Board</title>
  </head>

  <body>
    <%- include("nav") %>
    <main>
      <div class="single-card-div">
        <h1><%= message.user %> message</h1>
        <p><%= message.text %></p>
        <p class="date"><%= Intl.DateTimeFormat().format(message.added) %></p>
      </div>
    </main>
    <%- include("footer") %>
  </body>
</html>
